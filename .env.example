# Baseline local com Ollama e API OpenAI-compatible.
# Antes de executar, instale o Ollama e disponibilize o modelo configurado.
LLM_API_KEY=ollama
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=qwen2.5:7b
JUDGE_MODEL=qwen2.5:7b

# Caminhos e runtime portáteis (opcionais).
COTENEM_ENVIRONMENT=auto
COTENEM_DEVICE=auto
COTENEM_PRECISION=auto
COTENEM_OUTPUT_DIR=outputs
COTENEM_PERSISTENT_DIR=
COTENEM_CACHE_DIR=
HF_HOME=
HF_DATASETS_CACHE=
TORCH_HOME=
